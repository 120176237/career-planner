  flex-shrink: 0;
}

.rp-tag-mid {
  background: #3b82f6;
  color: #ffffff;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  font-size: 20rpx;
  flex-shrink: 0;
}

.rp-tag-short {
  background: #eab308;
  color: #ffffff;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  font-size: 20rpx;
  flex-shrink: 0;
}

.rp-tag-strength {
  background: #dcfce7;
  color: #15803d;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  font-size: 20rpx;
}

.rp-tag-limit {
  background: #fef3c7;
  color: #b45309;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  font-size: 20rpx;
}

.rp-tag-role {
  background: #eef2ff;
  color: #6366f1;
  padding: 8rpx 16rpx;
  border-radius: 9999rpx;
  font-size: 20rpx;
  white-space: nowrap;
}

.rp-tag-risk {
  background: #fffbeb;
  color: #d97706;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  font-size: 20rpx;
}

.rp-center {
  text-align: center;
}

.rp-mt-lg {
  margin-top: 64rpx;
}

.rp-mb-lg {
  margin-bottom: 48rpx;
}

.rp-mb-md {
  margin-bottom: 32rpx;
}

.rp-mb-sm {
  margin-bottom: 16rpx;
}

.rp-mt-xs {
  margin-top: 12rpx;
}

.rp-flex-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  flex-wrap: wrap;
  margin-bottom: 16rpx;
}

.rp-flex-row .rp-flex-left {
  flex: 1;
  min-width: 0;
}

.rp-flex-row .rp-flex-right {
  flex-shrink: 0;
}

.rp-flex-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 12rpx;
}

.rp-text-sm {
  font-size: 26rpx;
  color: #374151;
  word-break: break-all;
  overflow-wrap: break-word;
  white-space: normal;
  line-height: 1.6;
}

.rp-text-xs {
  font-size: 22rpx;
  color: #6b7280;
  word-break: break-all;
  overflow-wrap: break-word;
  white-space: normal;
  line-height: 1.5;
}

.rp-text-desc {
  font-size: 26rpx;
  color: #4b5563;
  word-break: break-all;
  overflow-wrap: break-word;
  white-space: normal;
  line-height: 1.6;
  margin-top: 12rpx;
}

.rp-vip-persona {
  background: linear-gradient(135deg, #faf5ff, #fdf2f8);
  border-radius: 24rpx;
  padding: 32rpx;
  border: 2rpx solid #f3e8ff;
  margin-bottom: 24rpx;
}

.rp-vip-skill {
  background: linear-gradient(135deg, #eff6ff, #eef2ff);
  border-radius: 24rpx;
  padding: 32rpx;
  border: 2rpx solid #dbeafe;
  margin-bottom: 24rpx;
}

.rp-vip-action {
  background: linear-gradient(135deg, #f0fdf4, #ecfdf5);
  border-radius: 24rpx;
  padding: 32rpx;
  border: 2rpx solid #bbf7d0;
  margin-bottom: 24rpx;
}

.rp-upgrade {
  background: linear-gradient(135deg, #fffbeb, #fefce8);
  border-radius: 32rpx;
  padding: 48rpx;
  border: 2rpx solid #fde68a;
  text-align: center;
  margin-top: 64rpx;
}

.rp-upgrade .rp-upg-title {
  font-weight: 500;
  color: #92400e;
  font-size: 28rpx;
  margin-bottom: 16rpx;
}

.rp-upgrade .rp-upg-desc {
  color: #d97706;
  font-size: 24rpx;
  margin-bottom: 32rpx;
}

/* 用户必看 - 免责声明 */
.disclaimer-section {
  margin-top: 48rpx;
  padding: 32rpx;
  background: linear-gradient(135deg, #fef3c7, #fde68a);
  border-radius: 24rpx;
  border: 2rpx solid #d97706;
}

.disclaimer-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #92400e;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.disclaimer-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.disclaimer-item {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  font-size: 24rpx;
  color: #78350f;
  line-height: 1.6;
}

.disclaimer-item::before {
  content: "•";
  color: #92400e;
  font-weight: 700;
  flex-shrink: 0;
}

/* 报告生成等待页面 - 与报告页面视觉统一 */
/* 等待页面头部 - 顶部图标区域 */
.waiting-header {
  text-align: center;
  padding: 48rpx 0 32rpx;
}

.waiting-icon-wrapper {
  display: inline-block;
  position: relative;
}

.waiting-icon-bg {
  width: 120rpx;
  height: 120rpx;
  background: linear-gradient(135deg, #eff6ff, #faf5ff);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid #e5e7eb;
  box-shadow: 0 8rpx 24rpx rgba(99, 102, 241, 0.15);
}

.waiting-loader {
  position: relative;
  width: 80rpx;
  height: 80rpx;
}

.loader-ring {
  position: absolute;
  border-radius: 50%;
  border: 3rpx solid #e5e7eb;
}

.loader-ring1 {
  width: 100%;
  height: 100%;
  border-top-color: #6366f1;
  animation: loaderSpin 2s linear infinite;
}

.loader-ring2 {
  width: 75%;
  height: 75%;
  top: 12.5%;
  left: 12.5%;
  border-top-color: #8b5cf6;
  animation: loaderSpin 1.5s linear infinite reverse;
}

.loader-center {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  display: flex;
  align-items: center;
  justify-content: center;
}

.loader-icon {
  font-size: 32rpx;
}

@keyframes loaderSpin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

/* 等待页面主卡片 - 匹配rp-card风格 */
.waiting-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 48rpx;
  margin: 0 32rpx 32rpx;
  border: 2rpx solid #e5e7eb;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.waiting-card-header {
  text-align: center;
  margin-bottom: 32rpx;
}

.waiting-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1e293b;
  display: block;
  margin-bottom: 12rpx;
}

.waiting-subtitle {
  font-size: 26rpx;
  color: #6366f1;
  display: block;
}

.waiting-divider {
  height: 2rpx;
  background: linear-gradient(90deg, transparent, #e5e7eb, transparent);
  margin: 32rpx 0;
}

/* 动态消息提示 */
.waiting-message {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  margin-bottom: 32rpx;
}

.waiting-message-text {
  font-size: 26rpx;
  color: #4b5563;
}

.waiting-dots {
  display: flex;
  gap: 4rpx;
}

.waiting-dot {
  font-size: 32rpx;
  color: #6366f1;
  animation: dotPulse 1.5s ease-in-out infinite;
}

.waiting-dot1 { animation-delay: 0s; }
.waiting-dot2 { animation-delay: 0.3s; }
.waiting-dot3 { animation-delay: 0.6s; }

@keyframes dotPulse {
  0%, 100% { opacity: 0.3; transform: scale(0.8); }
  50% { opacity: 1; transform: scale(1.2); }
}

/* 进度条 */
.waiting-progress-wrapper {
  text-align: center;
}

.waiting-progress-track {
  height: 8rpx;
  background: #f3f4f6;
  border-radius: 4rpx;
  overflow: hidden;
  margin-bottom: 16rpx;
}

.waiting-progress-bar {
  height: 100%;
  width: 60%;
  background: linear-gradient(90deg, #6366f1, #8b5cf6);
  border-radius: 4rpx;
  animation: progressSlide 2s ease-in-out infinite;
}

@keyframes progressSlide {
  0% { width: 0%; margin-left: 0%; }
  50% { width: 80%; margin-left: 10%; }
  100% { width: 0%; margin-left: 100%; }
}

.waiting-progress-tip {
  font-size: 22rpx;
  color: #9ca3af;
}

/* 功能特点展示 - 匹配报告页面的标签风格 */
.waiting-features {
  display: flex;
  gap: 16rpx;
  padding: 0 32rpx;
  justify-content: center;
  flex-wrap: wrap;
}

.waiting-feature-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  flex: 1;
  min-width: 140rpx;
  max-width: 200rpx;
}

.waiting-feature-icon-bg {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.waiting-feature-icon-bg-1 {
  background: linear-gradient(135deg, #eff6ff, #dbeafe);
  border: 2rpx solid #bfdbfe;
}

.waiting-feature-icon-bg-2 {
  background: linear-gradient(135deg, #faf5ff, #f3e8ff);
  border: 2rpx solid #e9d5ff;
}

.waiting-feature-icon-bg-3 {
  background: linear-gradient(135deg, #fef3c7, #fde68a);
  border: 2rpx solid #fcd34d;
}

.waiting-feature-icon {
  font-size: 36rpx;
}

.waiting-feature-text {
  font-size: 24rpx;
  color: #4b5563;
  text-align: center;
  font-weight: 500;
}
